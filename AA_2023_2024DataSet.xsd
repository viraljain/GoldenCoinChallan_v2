                    <CommandText>/*and CODE = 258*/
SELECT        Code AS DealerId, Name + ' (' + LOWER(ISNULL(Add1, '') + ' ' + ISNULL(Add2, '') + ' ' + ISNULL(Add3, '') + ' ' + ISNULL(Add4, '')) + ')' AS DealerName, TinCst AS GSTIN, PinCode
FROM            AccountMaster
WHERE        (GrpCode = 8)</CommandText>
                    <Parameters />
